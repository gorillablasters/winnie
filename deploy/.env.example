# Image tags published by the vendor.
# Separate-repository example:
# WINNIE_API_IMAGE=ghcr.io/your-org/winnie-api:latest
# WINNIE_DASHBOARD_IMAGE=ghcr.io/your-org/winnie-dashboard:latest
#
# Single Docker Hub repository example:
# WINNIE_API_IMAGE=gorillablasters/winnie:api-1.0.0
# WINNIE_DASHBOARD_IMAGE=gorillablasters/winnie:dashboard-1.0.0
WINNIE_API_IMAGE=gorillablasters/winnie-api:latest
WINNIE_DASHBOARD_IMAGE=gorillablasters/winnie-dashboard:latest

# Public ports on the deployment host.
WINNIE_API_PORT=8080
WINNIE_DASHBOARD_PORT=3000

# Database settings.
POSTGRES_DB=winnie
POSTGRES_USER=winnie
POSTGRES_PASSWORD=change-this-password

# API URL reachable from the browser.
# For local/self-hosted Docker usage, keep localhost and the chosen API port.
NEXT_PUBLIC_API_BASE=http://localhost:8080

# Demo data resets app data and seeds demo@example.com / password123.
# Keep false for customer production installs.
DEMO_DATA=false
RESET_APP_DATA=false
